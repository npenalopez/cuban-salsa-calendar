# Optional Supabase configuration.
# When BOTH variables are set, the app reads/writes festivals against the
# Supabase project. When either is missing, the app runs in localStorage
# mode and uses the seed data in src/app/data/festivals.ts.
#
# Copy this file to `.env` and fill in your own credentials.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
